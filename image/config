# pi-gen configuration for the GigDash image.
# Edit FIRST_USER_PASS before building, then run image/build.sh.
IMG_NAME=gigdash
RELEASE=bookworm
DEPLOY_COMPRESSION=xz

# stage2 is Raspberry Pi OS Lite; stage-gigdash layers the kiosk on top.
STAGE_LIST="stage0 stage1 stage2 stage-gigdash"

FIRST_USER_NAME=doug
FIRST_USER_PASS=changeme
DISABLE_FIRST_BOOT_USER_RENAME=1
ENABLE_SSH=1
TIMEZONE_DEFAULT=America/New_York
LOCALE_DEFAULT=en_US.UTF-8
KEYBOARD_KEYMAP=us
KEYBOARD_LAYOUT="English (US)"
